<?xml version="1.0"?>

<odoo>
    <record id="dankbit_liquidity_snapshot_view_form" model="ir.ui.view">
        <field name="name">dankbit_liquidity_snapshot.view.form</field>
        <field name="model">dankbit.liquidity.snapshot</field>
        <field name="arch" type="xml">
            <form string="Liquidity Snapshot">
                <sheet>
                    <group>
                        <field name="asset" />
                        <field name="as_of" />
                        <field name="lower_liq_price" />
                        <field name="lower_liq_m" />
                        <field name="upper_liq_price" />
                        <field name="upper_liq_m" />
                        <field name="note" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="dankbit_liquidity_snapshot_view_list" model="ir.ui.view">
        <field name="name">dankbit_liquidity_snapshot.view.list</field>
        <field name="model">dankbit.liquidity.snapshot</field>
        <field name="arch" type="xml">
            <list string="Liquidity Snapshots" default_order="as_of desc">
                <field name="asset" />
                <field name="as_of" />
                <field name="lower_liq_price" />
                <field name="lower_liq_m" />
                <field name="upper_liq_price" />
                <field name="upper_liq_m" />
                <field name="note" />
            </list>
        </field>
    </record>

    <record id="dankbit_liquidity_snapshot_view_search" model="ir.ui.view">
        <field name="name">dankbit.liquidity.snapshot.view.search</field>
        <field name="model">dankbit.liquidity.snapshot</field>
        <field name="arch" type="xml">
            <search string="Search Liquidity Snapshots">
                <field name="asset" string="Asset"/>

                <separator/>

                <filter name="only_btc" string="Only BTC" domain="[('asset', '=', 'BTC')]"/>
                <filter name="only_eth" string="Only ETH" domain="[('asset', '=', 'ETH')]"/>

                <group expand="0" string="Group By">
                    <filter string="Asset" name="asset" context="{'group_by':'asset'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="dankbit_liquidity_snapshot_action" model="ir.actions.act_window">
        <field name="name">Liquidity</field>
        <field name="res_model">dankbit.liquidity.snapshot</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'default_asset': 'BTC'}</field>
    </record>

    <menuitem id="dankbit_liquidity_snapshot_menu" name="Liquidity"
        action="dankbit_liquidity_snapshot_action"
        parent="dankbit_root_menu"
        sequence="60"/>
</odoo>
