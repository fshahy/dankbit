<?xml version="1.0"?>

<odoo>
    <record id="dankbit_forecast_log_view_form" model="ir.ui.view">
        <field name="name">dankbit_forecast_log.view.form</field>
        <field name="model">dankbit.forecast.log</field>
        <field name="arch" type="xml">
            <form string="Forecast Log">
                <sheet>
                    <group>
                        <field name="asset" />
                        <field name="generated_at" />
                        <field name="index_price" />
                        <field name="sigma_annual" />
                        <field name="hours_ahead" />
                        <field name="target_time" />
                        <field name="open" />
                        <field name="high" />
                        <field name="low" />
                        <field name="close" />
                        <field name="mode" />
                    </group>
                    <group string="Accuracy">
                        <field name="actual_price" />
                        <field name="error" />
                        <field name="error_pct" />
                        <field name="checked_at" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="dankbit_forecast_log_view_list" model="ir.ui.view">
        <field name="name">dankbit_forecast_log.view.list</field>
        <field name="model">dankbit.forecast.log</field>
        <field name="arch" type="xml">
            <list string="Forecast Log">
                <field name="asset" />
                <field name="generated_at" />
                <field name="hours_ahead" />
                <field name="target_time" />
                <field name="index_price" />
                <field name="open" />
                <field name="high" />
                <field name="low" />
                <field name="close" />
                <field name="actual_price" optional="show" />
                <field name="error" optional="show" />
                <field name="error_pct" optional="show" />
                <field name="mode" optional="hide" />
                <field name="sigma_annual" optional="hide" />
                <field name="checked_at" optional="hide" />
            </list>
        </field>
    </record>

    <record id="dankbit_forecast_log_view_pivot" model="ir.ui.view">
        <field name="name">dankbit_forecast_log.view.pivot</field>
        <field name="model">dankbit.forecast.log</field>
        <field name="arch" type="xml">
            <pivot string="Forecast Accuracy">
                <field name="asset" type="row"/>
                <field name="hours_ahead" type="row"/>
                <field name="mode" type="col"/>
                <field name="error" type="measure"/>
                <field name="error_pct" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="dankbit_forecast_log_view_search" model="ir.ui.view">
        <field name="name">dankbit.forecast.log.view.search</field>
        <field name="model">dankbit.forecast.log</field>
        <field name="arch" type="xml">
            <search string="Search Forecast Log">
                <field name="asset" string="Asset"/>
                <field name="generated_at" string="Generated At"/>
                <field name="target_time" string="Target Time"/>

                <separator/>

                <filter name="only_btc" string="Only BTC" domain="[('asset', '=', 'BTC')]"/>
                <filter name="only_eth" string="Only ETH" domain="[('asset', '=', 'ETH')]"/>
                <filter name="target_past" string="Target Time Passed" domain="[('target_time', '&lt;=', datetime.datetime.now())]"/>
                <filter name="checked" string="Checked" domain="[('checked_at', '!=', False)]"/>
                <filter name="unchecked" string="Unchecked" domain="[('checked_at', '=', False)]"/>

                <group expand="0" string="Group By">
                    <filter string="Asset" name="asset" context="{'group_by':'asset'}"/>
                    <filter string="Generated At" name="generated_at" context="{'group_by':'generated_at'}"/>
                    <filter string="Hours Ahead" name="hours_ahead" context="{'group_by':'hours_ahead'}"/>
                    <filter string="Mode" name="mode" context="{'group_by':'mode'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="dankbit_forecast_log_action" model="ir.actions.act_window">
        <field name="name">Forecast Log</field>
        <field name="res_model">dankbit.forecast.log</field>
        <field name="view_mode">list,pivot,form</field>
    </record>

    <menuitem id="dankbit_forecast_log_menu" name="Forecast Log"
        action="dankbit_forecast_log_action"
        parent="dankbit_root_menu"
        sequence="70"/>
</odoo>
