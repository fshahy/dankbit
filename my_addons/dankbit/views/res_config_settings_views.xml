<odoo>

    <record id="res_config_settings_view_form_inherit_dankbit" model="ir.ui.view">
        <field name="name">res.config.settings.inherit.dankbit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                 <app data-string="Dankbit" string="Dankbit" name="dankbit_settings">
                    <block title="General Settings" id="dankbit_graph_settings" groups="base.group_no_one">
                        <setting>
                            <field name="refresh_interval" placeholder="Refresh Interval"/>
                        </setting>
                        <setting>
                            <field name="zones_box_refresh_interval" placeholder="Zones Box Refresh Interval (s)"/>
                        </setting>
                        <setting>
                            <field name="deribit_timeout" placeholder="Deribit API timeout (s)"/>
                        </setting>
                        <setting>
                            <field name="deribit_cache_ttl" placeholder="Deribit cache TTL (s)"/>
                        </setting>
                    </block>

                    <block title="BTC Settings" id="dankbit_graph_settings" groups="base.group_no_one">
                        <setting>
                            <field name="from_price" placeholder="From Price"/>
                        </setting>
                        <setting>
                            <field name="to_price" placeholder="To Price"/>
                        </setting>
                        <setting>
                            <field name="steps" placeholder="Steps"/>
                        </setting>
                        <setting>
                            <field name="weekly_expiry" placeholder="e.g. BTC-3JUL26"/>
                        </setting>
                        <setting>
                            <field name="monthly_expiry" placeholder="e.g. BTC-31JUL26"/>
                        </setting>
                    </block>

                    <block title="TradingView Chart Settings" id="dankbit_tv_chart_settings" groups="base.group_no_one">
                        <setting>
                            <field name="show_daily_lines"/>
                        </setting>
                        <setting>
                            <field name="show_weekly_lines"/>
                        </setting>
                        <setting>
                            <field name="show_monthly_lines"/>
                        </setting>
                    </block>

                    <block title="ETH Settings" id="dankbit_eth_graph_settings" groups="base.group_no_one">
                        <setting>
                            <field name="eth_from_price" placeholder="ETH From Price"/>
                        </setting>
                        <setting>
                            <field name="eth_to_price" placeholder="ETH To Price"/>
                        </setting>
                        <setting>
                            <field name="eth_steps" placeholder="ETH Steps"/>
                        </setting>
                        <setting>
                            <field name="eth_weekly_expiry" placeholder="e.g. ETH-4JUL26"/>
                        </setting>
                        <setting>
                            <field name="eth_monthly_expiry" placeholder="e.g. ETH-26SEP26"/>
                        </setting>
                    </block>
                 </app>
            </xpath>
        </field>
    </record>

</odoo>