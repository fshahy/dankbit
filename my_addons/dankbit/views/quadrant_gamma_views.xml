<?xml version="1.0"?>

<odoo>
    <record id="dankbit_quadrant_gamma_view_form" model="ir.ui.view">
        <field name="name">dankbit_quadrant_gamma.view.form</field>
        <field name="model">dankbit.quadrant.gamma</field>
        <field name="arch" type="xml">
            <form string="Quadrant Gamma">
                <sheet>
                    <group>
                        <field name="asset" />
                        <field name="computed_at" />
                        <field name="index_price" />
                        <field name="buyer_call_gamma" />
                        <field name="buyer_put_gamma" />
                        <field name="seller_call_gamma" />
                        <field name="seller_put_gamma" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="dankbit_quadrant_gamma_view_list" model="ir.ui.view">
        <field name="name">dankbit_quadrant_gamma.view.list</field>
        <field name="model">dankbit.quadrant.gamma</field>
        <field name="arch" type="xml">
            <list string="Quadrant Gamma">
                <field name="asset" />
                <field name="computed_at" />
                <field name="index_price" />
                <field name="buyer_call_gamma" />
                <field name="buyer_put_gamma" />
                <field name="seller_call_gamma" />
                <field name="seller_put_gamma" />
            </list>
        </field>
    </record>

    <record id="dankbit_quadrant_gamma_view_search" model="ir.ui.view">
        <field name="name">dankbit.quadrant.gamma.view.search</field>
        <field name="model">dankbit.quadrant.gamma</field>
        <field name="arch" type="xml">
            <search string="Search Quadrant Gamma">
                <field name="asset" string="Asset"/>

                <separator/>

                <filter name="only_btc" string="Only BTC" domain="[('asset', '=', 'BTC')]"/>
                <filter name="only_eth" string="Only ETH" domain="[('asset', '=', 'ETH')]"/>

                <group expand="0" string="Group By">
                    <filter string="Asset" name="asset" context="{'group_by':'asset'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="dankbit_quadrant_gamma_action" model="ir.actions.act_window">
        <field name="name">Quadrant Gamma</field>
        <field name="res_model">dankbit.quadrant.gamma</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="dankbit_quadrant_gamma_menu" name="Quadrant Gamma"
        action="dankbit_quadrant_gamma_action"
        parent="dankbit_root_menu"
        sequence="40"/>
</odoo>
