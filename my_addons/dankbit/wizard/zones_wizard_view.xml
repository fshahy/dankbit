<odoo>

    <record id="view_zones_wizard_form" model="ir.ui.view">
        <field name="name">dankbit.zones.wizard.form</field>
        <field name="model">dankbit.zones_wizard</field>
        <field name="arch" type="xml">
            <form string="Zones Wizard">
                <group>
                    <field name="image_png" widget="image" nolabel="1"/>
                </group>
                <footer>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_open_zones_wizard" model="ir.actions.act_window">
        <field name="name">Open Zones Wizard</field>
        <field name="res_model">dankbit.zones_wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_zones_wizard_form"/>
        <field name="target">new</field>
    </record>

</odoo>
